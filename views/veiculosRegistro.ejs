<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8">
        <title>Registro de Veículos</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <body class="bg-light">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h3 class="card-title mb-4">Registro de Entrada / Saída de Veículos</h3>
                            
                            <%- include('partials/flashMessages') %>

                            <!-- Formulário de Entrada -->
                            <form action="/veiculos/registro/entrada" method="POST" class="mb-5">
                                <h5 class="card-subtitle mb-3 text-muted">Registrar Entrada</h5>
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-3">
                                        <label for="placa" class="form-label">Placa do Veículo:</label>
                                        <input 
                                            type="text" 
                                            class="form-control text-uppercase" 
                                            id="placa" 
                                            name="placa" 
                                            placeholder="Digite a placa" 
                                            required
                                        >
                                    </div>
                                    <div class="col-md-3">
                                        <label for="tipoVeiculo" class="form-label">Tipo de Veículo:</label>
                                        <select class="form-select" id="tipoVeiculo" name="tipoVeiculo" required>
                                            <option value="carro" selected>Carro</option>
                                            <option value="moto">Moto</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="tipoPagamento" class="form-label">Tipo de Pagamento:</label>
                                        <select class="form-select" id="tipoPagamento" name="tipoPagamento" required>
                                            <option value="pospago" selected>Pós-pago (Na Saída)</option>
                                            <option value="prepago">Pré-pago (Na Entrada)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-success w-100">Registrar Entrada</button>
                                    </div>
                                </div>
                            </form>

                            <!-- Tabela de Veículos Estacionados -->
                            <h5 class="card-subtitle mb-3 text-muted">Veículos Estacionados (Vagas Ocupadas)</h5>
                            <% if (registrosAtivos.length === 0) { %>
                                <div class="alert alert-info" role="alert">
                                    Não há veículos estacionados no momento.
                                </div>
                            <% } else { %>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Placa</th>
                                                <th>Tipo</th>
                                                <th>Tíquete</th>
                                                <th>Horário de Entrada</th>
                                                <th class="text-end">Ações</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% registrosAtivos.forEach((registro) => { %>
                                                <tr>
                                                    <td>
                                                        <span class="badge bg-secondary fs-6"><%= registro.placa %></span>
                                                    </td>
                                                    <td>
                                                        <% if (registro.tipoVeiculo === 'moto') { %>
                                                            <span class="badge bg-warning text-dark text-capitalize">Moto</span>
                                                        <% } else { %>
                                                            <span class="badge bg-info text-dark text-capitalize">Carro</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <% if (registro.Tiquete) { %>
                                                            <% if (registro.Tiquete.status === 'pago') { %>
                                                                <span class="badge bg-primary font-monospace fw-bold"><%= registro.Tiquete.codigo %></span>
                                                            <% } else { %>
                                                                <span class="badge bg-danger font-monospace fw-bold"><%= registro.Tiquete.codigo %></span>
                                                            <% } %>
                                                        <% } else { %>
                                                            <span class="text-muted">-</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <%= new Date(registro.horarioEntrada).toLocaleString('pt-BR') %>
                                                    </td>
                                                    <td class="text-end">
                                                        <% if (registro.Tiquete && registro.Tiquete.status === 'pago') { %>
                                                            <form action="/veiculos/registro/saida/<%= registro.id %>" method="POST" style="display: inline;">
                                                                <button type="submit" class="btn btn-danger btn-sm">Registrar Saída</button>
                                                            </form>
                                                        <% } else if (registro.Tiquete && registro.Tiquete.status === 'pendente') { %>
                                                            <form action="/tiquetes/pagar/<%= registro.Tiquete.id %>" method="POST" style="display: inline;" class="me-1">
                                                                <button type="submit" class="btn btn-success btn-sm">Pagar</button>
                                                            </form>
                                                            <form action="/veiculos/registro/saida-indevida/<%= registro.id %>" method="POST" style="display: inline;">
                                                                <button type="submit" class="btn btn-warning btn-sm">Saída Indevida</button>
                                                            </form>
                                                        <% } %>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        </div>
                        <div class="card-footer bg-white py-3">
                            <a href="/dashboard" class="btn btn-secondary">Voltar para o Dashboard</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
