<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8">
        <title>Histórico de Tíquetes</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <body class="bg-light">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-10">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h3 class="card-title mb-4">Histórico de Tíquetes</h3>
                            
                            <%- include('partials/flashMessages') %>

                            <!-- Formulário de Busca -->
                            <form action="/tiquetes" method="GET" class="mb-4">
                                <div class="input-group">
                                    <input 
                                        type="text" 
                                        class="form-control" 
                                        name="search" 
                                        placeholder="Buscar por placa do veículo ou código do tíquete..." 
                                        value="<%= search %>"
                                    >
                                    <button class="btn btn-primary" type="submit">Buscar</button>
                                    <% if (search) { %>
                                        <a href="/tiquetes" class="btn btn-secondary">Limpar</a>
                                    <% } %>
                                </div>
                            </form>

                            <!-- Tabela de Tíquetes -->
                            <% if (tiquetes.length === 0) { %>
                                <div class="alert alert-info" role="alert">
                                    Nenhum tíquete encontrado.
                                </div>
                            <% } else { %>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Código</th>
                                                <th>Placa</th>
                                                <th>Tipo</th>
                                                <th>Entrada</th>
                                                <th>Valor</th>
                                                <th>Status</th>
                                                <th>Criado Por</th>
                                                <th>Validado Por</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% tiquetes.forEach((ticket) => { %>
                                                <tr>
                                                    <td>
                                                        <span class="font-monospace fw-bold"><%= ticket.codigo %></span>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-secondary fs-6"><%= ticket.Registro ? ticket.Registro.placa : '-' %></span>
                                                    </td>
                                                    <td>
                                                        <% if (ticket.Registro) { %>
                                                            <% if (ticket.Registro.tipoVeiculo === 'moto') { %>
                                                                <span class="badge bg-warning text-dark text-capitalize">Moto</span>
                                                            <% } else { %>
                                                                <span class="badge bg-info text-dark text-capitalize">Carro</span>
                                                            <% } %>
                                                        <% } else { %>
                                                            <span class="text-muted">-</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <%= ticket.Registro ? new Date(ticket.Registro.horarioEntrada).toLocaleString('pt-BR') : '-' %>
                                                    </td>
                                                    <td>
                                                        R$ <%= Number(ticket.valor).toFixed(2).replace('.', ',') %>
                                                    </td>
                                                    <td>
                                                        <% if (ticket.status === 'pago') { %>
                                                            <span class="badge bg-primary">Pago</span>
                                                        <% } else { %>
                                                            <span class="badge bg-danger">Pendente</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <%= ticket.CriadoPor ? ticket.CriadoPor.name : 'Sistema' %>
                                                    </td>
                                                    <td>
                                                        <%= ticket.ValidadoPor ? ticket.ValidadoPor.name : '-' %>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        </div>
                        <div class="card-footer bg-white py-3">
                            <a href="/dashboard" class="btn btn-secondary">Voltar para o Dashboard</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
